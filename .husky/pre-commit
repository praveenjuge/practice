#!/bin/sh
# Exit on any error and undefined variable
set -eu

# Check if there are any staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$STAGED_FILES" ]; then
  echo "No staged files to format"
  exit 0
fi

# Keep hook scoped to staged files to avoid unrelated repo-wide failures.
set --
while IFS= read -r file; do
  case "$file" in
    *.js|*.jsx|*.cjs|*.mjs|*.ts|*.tsx|*.cts|*.mts|*.json|*.jsonc)
      set -- "$@" "$file"
      ;;
  esac
done <<EOF
$STAGED_FILES
EOF

if [ "$#" -eq 0 ]; then
  echo "No staged JS/TS/JSON files for Ultracite"
  exit 0
fi

# Run formatter, then continue so we can still re-stage touched files
set +e
bun x ultracite fix "$@"
FORMAT_EXIT_CODE=$?
set -e

# Re-stage files that were already staged
echo "$STAGED_FILES" | while IFS= read -r file; do
  if [ -f "$file" ]; then
    git add "$file"
  fi
done

if [ "$FORMAT_EXIT_CODE" -ne 0 ]; then
  echo "Ultracite found issues that could not be auto-fixed."
  exit $FORMAT_EXIT_CODE
fi

echo "✨ Files formatted by Ultracite"
