{
  "name": "practice",
  "version": "1.2.0",
  "main": "expo-router/entry",
  "scripts": {
    "android": "JAVA_HOME=${JAVA_HOME:-/opt/homebrew/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home} ANDROID_HOME=${ANDROID_HOME:-$HOME/Library/Android/sdk} expo run:android",
    "build:android:internal": "eas build --platform android --profile preview",
    "build:local": "eas build --platform ios --local",
    "build:submit": "eas submit --platform ios",
    "check": "ultracite check",
    "dev": "bun run --parallel ios dev:convex",
    "dev:convex": "convex dev",
    "fix": "ultracite fix",
    "ios": "expo run:ios",
    "metadata:pull": "eas metadata:pull",
    "metadata:push": "eas metadata:push",
    "prepare": "husky",
    "serve:web": "expo serve",
    "start": "expo start",
    "web": "expo start --web",
    "build:web": "expo export --platform web --clear",
    "deploy:dry-run": "bun run build:web && wrangler deploy --dry-run",
    "deploy": "convex deploy --cmd \"expo export --platform web --clear\" && wrangler deploy"
  },
  "dependencies": {
    "@clerk/expo": "^3.2.16",
    "@clerk/expo-passkeys": "^1.0.29",
    "@expo/material-symbols": "^0.1.1",
    "@expo/ui": "~56.0.14",
    "@types/react": "^19.2.14",
    "convex": "^1.39.1",
    "expo": "~56.0.4",
    "expo-apple-authentication": "~56.0.4",
    "expo-auth-session": "~56.0.12",
    "expo-build-properties": "~56.0.15",
    "expo-constants": "~56.0.16",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.16",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-linking": "~56.0.12",
    "expo-local-authentication": "~56.0.4",
    "expo-router": "~56.2.7",
    "expo-secure-store": "~56.0.4",
    "expo-sqlite": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-web-browser": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-cloud-storage": "^3.0.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2",
    "typescript": "~6.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.9.1",
    "husky": "^9.1.7",
    "ultracite": "^7.6.3",
    "wrangler": "^4.94.0"
  }
}
