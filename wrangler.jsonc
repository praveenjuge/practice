{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "practice",
  "compatibility_date": "2026-05-25",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "practice.praveenjuge.com",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
